<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%=title %> Project</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/index.css">
  </head>
  <body>
    <h1><%=title %></h1>
    <div class="new-message">
        <a href="/new" class="btn btn-add">Create Message</a>
    </div>
    <div class="message-container">
    <% if (locals.messages && messages.length > 0) { %>
        <% messages.forEach(message => { %>
            <div class="message-card">
                <div class="message-header">
                    <span class="sender-name"><%= message.username %></span>
                    <span class="message-date"><%= message.created_at.toDateString() %></span>
                </div>
                <div class="message-body">
                    <p><%= message.message_text %></p>
                </div>
               <div class="message-actions">
                <a href="/<%=message.id%>/edit" class="btn btn-edit">
                    <img src="icons/edit-icon.png" alt="edit icon">
                </a>
                <form method="POST" action="/<%= message.id %>/delete" class="delete-form">
                    <button type="submit" class="btn btn-delete">
                        <img src="icons/delete-icon.png" alt="delete icon">
                    </button>
                </form>
               </div> 
            </div>
        <% }); %>
     <%} else { %>
        <p>No messages yet!</p>
     <%} %>
 </div>
</body>
</html>
